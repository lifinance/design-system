{
	"name": "@lifi/design-system-core",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "LI.FI core design system, distributed as a shadcn registry.",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"check:ci": "biome ci",
		"registry:build": "pnpm registry:build:core && pnpm registry:build:widget",
		"registry:build:core": "shadcn build",
		"registry:build:widget": "shadcn build registry.widget.json --output public/r/widget"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.487.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.3.1",
		"tw-animate-css": "^1.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/vite": "^4.1.11",
		"@types/node": "^22.10.0",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@vitejs/plugin-react": "^4.4.1",
		"shadcn": "^4.11.0",
		"tailwindcss": "^4.1.11",
		"typescript": "~5.9.2",
		"vite": "^6.3.5"
	}
}
