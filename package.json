{
	"name": "@lifi/design-system-core",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "LI.FI core design system, distributed as a shadcn registry.",
	"scripts": {
		"typecheck": "tsc -b",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"check:ci": "biome ci",
		"test:storybook": "vitest run",
		"registry:build": "rm -rf public/r && pnpm registry:build:core && pnpm registry:build:widget && pnpm registry:build:perps && pnpm registry:build:jumper",
		"registry:build:core": "node scripts/build-registry.mjs registry.json core public/r/core",
		"registry:build:widget": "node scripts/build-registry.mjs registry.widget.json widget public/r/widget",
		"registry:build:perps": "node scripts/build-registry.mjs registry.perps.json perps public/r/perps",
		"registry:build:jumper": "node scripts/build-registry.mjs registry.jumper.json jumper public/r/jumper",
		"dev": "pnpm storybook",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"chromatic": "chromatic"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.17.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.3.1",
		"tw-animate-css": "^1.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@figma/code-connect": "^1.4.8",
		"@storybook/addon-a11y": "^10.4.3",
		"@storybook/addon-designs": "^11.1.3",
		"@storybook/addon-docs": "^10.4.3",
		"@storybook/addon-mcp": "^0.6.0",
		"@storybook/addon-vitest": "^10.4.3",
		"@storybook/react-vite": "^10.4.3",
		"@tailwindcss/vite": "^4.1.11",
		"@types/node": "^22.10.0",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser-playwright": "^4.1.8",
		"chromatic": "^17.4.1",
		"playwright": "^1.60.0",
		"shadcn": "^4.11.0",
		"storybook": "^10.4.3",
		"tailwindcss": "^4.1.11",
		"typescript": "~6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=22"
	}
}
