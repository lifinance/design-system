{
	"name": "@lifi/design-system-core",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "LI.FI core design system, distributed as a shadcn registry.",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"check:ci": "biome ci",
		"registry:build": "pnpm registry:build:core && pnpm registry:build:widget",
		"registry:build:core": "shadcn build",
		"registry:build:widget": "shadcn build registry.widget.json --output public/r/widget",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.17.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.3.1",
		"tw-animate-css": "^1.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@chromatic-com/storybook": "^5.2.1",
		"@storybook/addon-a11y": "^10.4.2",
		"@storybook/addon-docs": "^10.4.2",
		"@storybook/addon-mcp": "^0.6.0",
		"@storybook/addon-vitest": "^10.4.2",
		"@storybook/react-vite": "^10.4.2",
		"@tailwindcss/vite": "^4.1.11",
		"@types/node": "^22.10.0",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"playwright": "^1.60.0",
		"shadcn": "^4.11.0",
		"storybook": "^10.4.2",
		"tailwindcss": "^4.1.11",
		"typescript": "~6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
