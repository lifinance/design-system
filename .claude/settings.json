{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"enableAllProjectMcpServers": true,
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/announce-skills.sh"
					},
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/launch-storybook.sh",
						"statusMessage": "Ensuring Storybook is running for the Storybook MCP"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/require-skills.sh",
						"statusMessage": "Checking project skill rules"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/migration-intent.sh"
					}
				]
			}
		]
	}
}
