{
	"$schema": "https://ui.shadcn.com/schema/registry.json",
	"name": "widget",
	"homepage": "https://github.com/lifinance/design-system",
	"items": [
		{
			"name": "tokens",
			"type": "registry:theme",
			"title": "LI.FI widget tokens",
			"description": "Widget token layer. Carries the widget brand role tokens plus --lifi-input-* overrides that re-theme @core/input. Builds on @core/tokens.",
			"registryDependencies": ["@core/tokens"],
			"cssVars": {
				"light": {
					"radius": "0.75rem",
					"font-sans": "Inter, sans-serif",
					"background": "#ffffff",
					"card": "#ffffff",
					"foreground": "#000000",
					"primary": "#5c67ff",
					"primary-foreground": "#ffffff",
					"muted-foreground": "#747474",
					"border": "#e0e0e0",
					"input": "#e0e0e0",
					"ring": "#5c67ff",
					"destructive": "#e5452f",
					"lifi-input-height": "2.875rem",
					"lifi-input-radius": "var(--radius)",
					"lifi-input-background": "var(--background)",
					"lifi-input-font-size": "1rem",
					"lifi-input-font-weight": "500"
				},
				"dark": {
					"background": "#212121",
					"card": "#212121",
					"foreground": "#ffffff",
					"primary": "#5c67ff",
					"primary-foreground": "#ffffff",
					"muted-foreground": "#bbbbbb",
					"border": "#424242",
					"input": "#424242",
					"ring": "#5c67ff",
					"destructive": "#e5452f",
					"lifi-input-background": "var(--background)"
				}
			}
		}
	]
}
