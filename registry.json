			"registryDependencies": ["@core/tokens"],
			"files": [
				{
					"path": "registry/core/ui/separator.tsx",
					"type": "registry:ui"
				}
			]
		},
		{
			"name": "card",
			"type": "registry:ui",
			"title": "Card",
