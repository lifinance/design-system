{
	"$schema": "https://ui.shadcn.com/schema/registry.json",
	"name": "core",
	"homepage": "https://github.com/lifinance/design-system",
	"items": [
		{
			"name": "tokens",
			"type": "registry:theme",
			"title": "LI.FI base tokens",
			"description": "The base color, radius, and typography tokens that every theme builds on.",
			"cssVars": {
				"theme": {
					"color-success": "var(--success)",
					"color-warning": "var(--warning)",
					"color-info": "var(--info)",
					"color-button-primary-hover": "var(--lifi-button-primary-hover)",
					"color-button-primary-active": "var(--lifi-button-primary-active)",
					"color-button-primary-focus": "var(--lifi-button-primary-focus)",
					"radius-button": "var(--lifi-button-radius)"
				},
				"light": {
					"radius": "0.625rem",
					"lifi-button-radius": "var(--radius)",
					"lifi-button-primary-hover": "color-mix(in oklch, var(--primary), var(--primary-foreground) 12%)",
					"lifi-button-primary-active": "color-mix(in oklch, var(--primary), var(--primary-foreground) 20%)",
					"lifi-button-primary-focus": "var(--ring)",
